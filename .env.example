# Variables consumed by docker-compose.yml at the repo root.
# Copy to `.env` (kept out of git) and adjust for your setup.

# --- shared ---------------------------------------------------------------
LOG_LEVEL=INFO

# --- maxapi side ----------------------------------------------------------
# Bearer token expected on `Authorization: Bearer <MAXAPI_TOKEN>`.
MAXAPI_TOKEN=dev-token
# `memory` (in-process stub, default) or `pymax` (real MAX userbot).
MAXAPI_BACKEND=memory

# --- bridge addressing ----------------------------------------------------
# MAX account id (acc_*) the bridge publishes from.
# The default account+channel below come from maxapi's seeded demo data
# and only work with MAXAPI_BACKEND=memory.
MAXAPI_ACCOUNT_ID=acc_DEMO0000000000000000000000
MAXAPI_CHANNEL_ID=-1001111111111

# --- parser side ----------------------------------------------------------
# HMAC-SHA256 secret used to verify maxapi webhooks. Leave empty for
# local development with no webhooks; otherwise it MUST match the secret
# you registered with `POST /v1/webhook-subscriptions`.
MAXAPI_WEBHOOK_SECRET=
